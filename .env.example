PORT=5000
NODE_ENV=production

# Database (MongoDB Atlas)
# 1. Create a free cluster at https://www.mongodb.com/cloud/atlas
# 2. Add a database user and whitelist IP 0.0.0.0/0
# 3. Get your connection string: mongodb+srv://<user>:<password>@cluster0.mongodb.net/dbname
MONGO_URI=mongodb+srv://admin:password@cluster0.mongodb.net/waitless

# Cache & Message Queue (Upstash Redis for Production)
REDIS_URL=rediss://default:<password>@cluster-name.upstash.io:6379

# Cache & Message Queue (Render Redis or Upstash)
# 1. On Render: Create a 'Redis' instance. Use the 'Internal Redis URL' for server-to-redis communication.
# 2. On Upstash: Create a database at https://upstash.com and copy the 'Node.js'  connection URL.
# Note: Use 'rediss://' for secure cloud connections to avoid ECONNRESET.

REDIS_URL=rediss://default:password@your-redis-instance.com:6379
 
# Authentication Secrets
# Generate strong keys using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_long_random_access_token_secret_here
REFRESH_SECRET=your_long_random_refresh_token_secret_here

# AI Configuration (Gemini API)
# Get your API key at https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Frontend URL (Vercel/Netlify URL for Production)
CLIENT_URL=http://localhost:3000